{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(xkill:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(systemctl:stop*)",
      "Bash(systemctl:restart*)",
      "Bash(service:*stop*)",
      "Bash(service:*restart*)",
      "Bash(rm:-rf /*)",
      "Bash(rm:-rf ~/*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(sudo:*)",
      "Bash(su:-*)",
      "Bash(*:/opt/render/project*)",
      "Bash(*:/etc/*)",
      "Bash(*:/var/*)",
      "Read(/opt/render/project*)",
      "Write(/opt/render/project*)",
      "Edit(/opt/render/project*)",
      "Read(/etc/*)",
      "Write(/etc/*)",
      "Read(/var/*)",
      "Write(/var/*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git clone:*)",
      "Bash(git remote add:*)",
      "Bash(git remote set-url:*)",
      "Bash(*.git/config*)",
      "Bash(*cat*.git/config*)",
      "Read(*.git/config*)",
      "Bash(git remote -v*)",
      "Bash(git remote get-url*)",
      "Bash(*curl*api.github.com*)",
      "Bash(*wget*api.github.com*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}